#!/usr/bin/env bash
set -euo pipefail

find_lib_dir() {
  if [[ -n "${AGENTIC_TMUX_LIB:-}" && -d "$AGENTIC_TMUX_LIB" ]]; then
    printf '%s' "$AGENTIC_TMUX_LIB"
    return 0
  fi
  local bin
  bin="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$bin/../lib" ]]; then
    printf '%s' "$(cd "$bin/../lib" && pwd)"
    return 0
  fi
  if [[ -d "${HOME}/.local/share/agentic-tmux/lib" ]]; then
    printf '%s' "${HOME}/.local/share/agentic-tmux/lib"
    return 0
  fi
  return 1
}

load_libs() {
  local lib
  lib="$(find_lib_dir)" || {
    printf 'error: cannot find agentic-tmux lib (re-run install.sh)\n' >&2
    exit 1
  }
  # shellcheck source=/dev/null
  source "$lib/common.sh"
  # shellcheck source=/dev/null
  source "$lib/detect.sh"
  # shellcheck source=/dev/null
  source "$lib/deps.sh"
  # shellcheck source=/dev/null
  source "$lib/config.sh"
  # shellcheck source=/dev/null
  source "$lib/shell-rc.sh"
  # shellcheck source=/dev/null
  source "$lib/uninstall.sh"
  # shellcheck source=/dev/null
  source "$lib/help.sh"
}

cmd_doctor() {
  log "agentic-tmux doctor (v${AGENTIC_TMUX_VERSION})"
  log ""
  log "Dependencies:"
  doctor_dependencies || true
  log ""
  log "Integration:"
  local rc
  rc="$(shell_rc_for "$(detect_shell_name)")"
  if has_marker_block "$rc"; then
    log "  ok  marker block in $rc"
  else
    log "  missing  marker block in $rc"
  fi
  if [[ -f "$AGENTIC_TMUX_USER_CONFIG" ]]; then
    log "  ok  $AGENTIC_TMUX_USER_CONFIG (agent=$(read_agent_command))"
  else
    log "  missing  $AGENTIC_TMUX_USER_CONFIG"
  fi
  [[ -f "$TMUX_CONFIG_DIR/tmux.conf" ]] && log "  ok  tmux.conf" || log "  missing  tmux.conf"
  [[ -f "$WORKTRUNK_CONFIG_DIR/dev-layout.sh" ]] && log "  ok  dev-layout.sh" || log "  missing  dev-layout.sh"
  [[ -f "$WORKTRUNK_CONFIG_DIR/dev-layout-cmd.sh" ]] && log "  ok  dev-layout-cmd.sh" || log "  missing  dev-layout-cmd.sh"
}

cmd_update() {
  FORCE=0
  deploy_configs
  install_shell_integration || true
  show_summary
}

cmd_reconfigure() {
  FORCE=1
  prompt_agent_command
  info "agent command updated — new tmux sessions will use: $(read_agent_command)"
  info "restart agent panes or run 'dev' in a new session to apply"
}

usage() {
  cat <<EOF
Usage: agentic-tmux <command>

Commands:
  help          Show full help
  doctor        Check dependencies and integration
  update        Re-sync configs
  reconfigure   Re-prompt agent command
  dry-run       Show planned install actions
  uninstall     Remove integration

Run 'agentic-tmux help' for shell commands and keybindings.
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      load_libs
      show_help
      ;;
    doctor)
      load_libs
      cmd_doctor
      ;;
    update)
      load_libs
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force|-f) FORCE=1; shift ;;
          *) die "unknown option: $1" ;;
        esac
      done
      cmd_update
      ;;
    reconfigure)
      load_libs
      cmd_reconfigure
      ;;
    dry-run)
      load_libs
      DRY_RUN=1
      YES=1
      install_dependencies
      deploy_configs
      install_shell_integration || true
      ;;
    uninstall)
      load_libs
      uninstall_agentic_tmux
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
